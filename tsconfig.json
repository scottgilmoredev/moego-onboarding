{
  "compilerOptions": {
    "target": "ES2019",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2019", "DOM"],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "paths": {
      "#/*": ["./src/*"]
    },
    "types": ["vitest/globals", "node", "google-apps-script"],
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "*.ts", "*.d.ts"],
  "exclude": ["node_modules", "dist"]
}
